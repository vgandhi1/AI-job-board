# ============================================
# AI Job Board - Environment Configuration
# ============================================
# A single .env file at the project root is shared by:
#   - the backend (read by app/config.py)
#   - the Next.js frontend (NEXT_PUBLIC_* variables)
#   - docker-compose (postgres + backend)

# --- Database (backend, asyncpg) ---
# In docker-compose, host=postgres. For local dev, host=localhost.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobboard

# --- Postgres container creds (docker-compose) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobboard

# ============================================
# AI provider (choose one)
# ============================================
# LLM_PROVIDER selects which backend powers embeddings + fit-analysis:
#   openai  -> hosted OpenAI APIs   (requires OPENAI_API_KEY)
#   ollama  -> local Ollama server  (no API key, runs on Windows host)
LLM_PROVIDER=openai

# --- OpenAI (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# --- Ollama (used when LLM_PROVIDER=ollama) ---
# Ollama runs on the Windows host, the app runs in WSL/Docker. The default
# URL works for docker-compose (we add a host.docker.internal -> host-gateway
# extra_hosts mapping in docker-compose.yml). For a backend running directly
# in WSL (no Docker), replace with http://<windows-host-ip>:11434 - get the
# IP with:  ip route show default | awk '{print $3}'
# IMPORTANT: on Windows, start Ollama with OLLAMA_HOST=0.0.0.0 so it accepts
# connections from outside localhost.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_ANALYSIS_MODEL=llama3.1
# Ollama ignores this; the openai SDK requires a non-empty value.
OLLAMA_API_KEY=ollama

# --- Embedding dimension ---
# MUST match the embedding model. Mismatch will break the pgvector column.
# If you change this, run: python backend/scripts/reset_embedding_dimension.py
#   OpenAI text-embedding-3-small : 1536  (default)
#   OpenAI text-embedding-3-large : 3072
#   Ollama nomic-embed-text       : 768
#   Ollama mxbai-embed-large      : 1024
#   Ollama bge-large              : 1024
#   Ollama all-minilm             : 384
EMBEDDING_DIMENSION=1536

# --- App ---
DEBUG=false
APP_NAME=AI Job Board API
LOG_LEVEL=INFO

# --- Frontend ---
# In dev: http://localhost:8000 (direct to backend)
# In prod (Nginx): /api (same-origin reverse-proxy path)
NEXT_PUBLIC_API_URL=http://localhost:8000
